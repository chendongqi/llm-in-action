# ============================================
# LLM Provider 选择
# 可选值：zhipu | openai | ollama | azure
# ============================================
LLM_PROVIDER=zhipu

# --- 智谱 AI 配置（默认）---
LLM_API_KEY=xxxx
LLM_MODEL=glm-4-flash
# 是否启用 thinking 深度推理模式
LLM_ZHIPU_THINKING=false

# --- OpenAI 模式配置 ---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxxxxxxxxxxx
# LLM_MODEL=gpt-4o-mini
# LLM_API_BASE=https://api.openai.com/v1

# --- 本地 Ollama 模式 ---
# LLM_PROVIDER=ollama
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:latest
# LLM_API_BASE=http://localhost:11434/v1

# ============================================
# Embedding 模型配置
# SiliconFlow (OpenAI 兼容 API) 或 OpenAI
# ============================================
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=xxxx
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSIONS=1024
EMBEDDING_MAX_CHARS=500

# ============================================
# 向量数据库
# ============================================
# ChromaDB 本地存储（默认，开发用）
VECTOR_DB=chroma
PERSIST_DIRECTORY=./chroma_db

# Qdrant 云端（生产用）
# VECTOR_DB=qdrant
# QDRANT_URL=xxxx
# QDRANT_API_KEY=xxxx
# QDRANT_COLLECTION=xxxx
